Cell[BoxData[
 RowBox[{
  RowBox[{"Schu", "[", 
   RowBox[{"n_", ",", "d_", ",", 
    RowBox[{"nota_", ":", "a"}]}], "]"}], ":=", 
  RowBox[{"SchurPolynomial", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"nota", "[", "i", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"d", "-", "2"}]}], "]"}], ",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"147cc656-5942-4899-b3a5-6c7d3d34d895"],

Cell[BoxData[
 RowBox[{
  RowBox[{"InvRSL", "[", 
   RowBox[{"X_", ",", "d_", ",", 
    RowBox[{"nota1_", ":", "a"}], ",", 
    RowBox[{"nota2_", ":", "b"}]}], "]"}], ":=", 
  RowBox[{"Product", "[", 
   RowBox[{
    RowBox[{"Product", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"nota1", "[", "i", "]"}], "*", 
         RowBox[{"nota2", "[", "j", "]"}], " ", "X"}]}], ")"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "1", ",", "d"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"8553861b-7410-422c-b4de-05d08e34f291"],

Cell[BoxData[
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"d_", ",", "k_", ",", "l_"}], "]"}], ":=", 
  RowBox[{"Cancel", "[", 
   RowBox[{
    RowBox[{"InvRSL", "[", 
     RowBox[{"x", ",", "d", ",", "a", ",", "b"}], "]"}], "*", " ", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Schu", "[", 
        RowBox[{
         RowBox[{"m", "+", "k"}], ",", "d", ",", "a"}], "]"}], " ", "*", 
       RowBox[{"Schu", "[", 
        RowBox[{
         RowBox[{"m", "+", "l"}], ",", "d", ",", "b"}], "]"}], " ", 
       RowBox[{"x", "^", "m"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellChangeTimes->{{3.9885666524306707`*^9, 3.988566659477373*^9}},
 CellLabel->"In[5]:=",ExpressionUUID->"7c6554c6-c507-42da-8832-8db5fe09c3cd"],

