Cell[BoxData[
 RowBox[{
  RowBox[{"Schu", "[", 
   RowBox[{"n_", ",", "d_", ",", 
    RowBox[{"nota_", ":", "a"}]}], "]"}], ":=", 
  RowBox[{"SchurPolynomial", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"nota", "[", "i", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"d", "-", "2"}]}], "]"}], ",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"147cc656-5942-4899-b3a5-6c7d3d34d895"],

Cell[BoxData[
 RowBox[{
  RowBox[{"InvRSL", "[", 
   RowBox[{"X_", ",", "d_", ",", 
    RowBox[{"nota1_", ":", "a"}], ",", 
    RowBox[{"nota2_", ":", "b"}]}], "]"}], ":=", 
  RowBox[{"Product", "[", 
   RowBox[{
    RowBox[{"Product", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"nota1", "[", "i", "]"}], "*", 
         RowBox[{"nota2", "[", "j", "]"}], " ", "X"}]}], ")"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
