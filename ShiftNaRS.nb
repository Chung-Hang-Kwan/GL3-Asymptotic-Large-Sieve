Cell[BoxData[
 RowBox[{
  RowBox[{"coeffsAndMonoms", "[", 
   RowBox[{"p_", ",", "vars_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"rules", ",", "exps", ",", "coeffs", ",", "monoms"}], "}"}], ",", 
    RowBox[{
     RowBox[{"rules", "=", 
      RowBox[{"CoefficientRules", "[", 
       RowBox[{"p", ",", "vars"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"exps", "=", 
      RowBox[{"Keys", "[", "rules", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"coeffs", "=", 
      RowBox[{"Values", "[", "rules", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"monoms", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Times", "@@", 
         RowBox[{"MapThread", "[", 
          RowBox[{"Power", ",", 
           RowBox[{"{", 
            RowBox[{"vars", ",", "#"}], "}"}]}], "]"}]}], "&"}], "/@", 
       "exps"}]}], ";", 
     RowBox[{"{", 
      RowBox[{"coeffs", ",", "monoms"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[12]:=",ExpressionUUID->"646de181-9d9b-4172-a252-6e118ec5a157"],

