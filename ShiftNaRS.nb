Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OmegaRule2", "[", 
    RowBox[{"\[Omega]_", ",", 
     RowBox[{"ass_", ":", "True"}]}], "]"}], ":=", 
   RowBox[{
    RowBox[{"HoldPattern", "[", 
     RowBox[{"c_.", " ", 
      RowBox[{
       RowBox[{"a", "[", "1", "]"}], "^", "p_."}], " ", 
      RowBox[{
       RowBox[{"a", "[", "2", "]"}], "^", "q_."}]}], "]"}], ":>", 
    RowBox[{"With", "[", 
     RowBox[{
      RowBox[{"{", 
       RowBox[{"s", "=", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{
          RowBox[{"Min", "[", 
           RowBox[{"p", ",", "q"}], "]"}], ",", "ass"}], "]"}]}], "}"}], ",", 
      
      RowBox[{"c", " ", 
       RowBox[{"\[Omega]", "^", "s"}], " ", 
       RowBox[{
        RowBox[{"a", "[", "1", "]"}], "^", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{
          RowBox[{"p", "-", "s"}], ",", "ass"}], "]"}]}], " ", 
       RowBox[{
        RowBox[{"a", "[", "2", "]"}], "^", 
        RowBox[{"FullSimplify", "[", 
         RowBox[{
          RowBox[{"q", "-", "s"}], ",", "ass"}], "]"}]}]}]}], "]"}]}]}], 
  ";"}]], "Input",
 CellChangeTimes->{{3.988568049844751*^9, 3.988568070065898*^9}},
 CellLabel->"In[10]:=",ExpressionUUID->"fb6c0902-3eb0-4123-b369-3a97a5c871db"],

Cell[BoxData[
 RowBox[{
  RowBox[{
   RowBox[{"OmegaRule3", "[", 
    RowBox[{"\[Omega]_", ",", 
     RowBox[{"ass_", ":", "True"}]}], "]"}], ":=", 
