Cell[BoxData[
 RowBox[{
  RowBox[{"FinalPoly", "[", 
   RowBox[{"d_", ",", "k_", ",", "l_", ",", "sgn_"}], "]"}], ":=", 
  RowBox[{"Total", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{
       RowBox[{
        RowBox[{"PartA", "[", 
         RowBox[{"d", ",", "k", ",", "l"}], "]"}], "[", 
        RowBox[{"[", 
         RowBox[{"All", ",", "2"}], "]"}], "]"}], "/.", 
       RowBox[{"\[Omega]", "->", "sgn"}]}], ")"}], "*", 
     RowBox[{"(", 
      RowBox[{
       RowBox[{"(", 
        RowBox[{
         RowBox[{"PartACollect", "[", 
          RowBox[{"d", ",", "k", ",", "l", ",", "\[Omega]"}], "]"}], "/.", 
         RowBox[{"\[Omega]", "->", "sgn"}]}], ")"}], "//.", 
       RowBox[{"{", 
        RowBox[{
