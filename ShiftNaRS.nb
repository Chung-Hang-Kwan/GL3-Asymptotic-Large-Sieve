        RowBox[{
         RowBox[{"m", "+", "l"}], ",", "d", ",", "b"}], "]"}], " ", 
       RowBox[{"x", "^", "m"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
