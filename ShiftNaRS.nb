Cell[BoxData[
 RowBox[{
  RowBox[{"R", "[", 
   RowBox[{"d_", ",", "k_", ",", "l_"}], "]"}], ":=", 
  RowBox[{"Cancel", "[", 
   RowBox[{
    RowBox[{"InvRSL", "[", 
     RowBox[{"x", ",", "d", ",", "a", ",", "b"}], "]"}], "*", " ", 
    RowBox[{"Sum", "[", 
