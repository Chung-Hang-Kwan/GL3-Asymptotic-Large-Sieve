Cell[BoxData[
 RowBox[{
  RowBox[{"Schu", "[", 
   RowBox[{"n_", ",", "d_", ",", 
    RowBox[{"nota_", ":", "a"}]}], "]"}], ":=", 
  RowBox[{"SchurPolynomial", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"nota", "[", "i", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"d", "-", "2"}]}], "]"}], ",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], "]"}]}]], "Input",
 CellLabel->"In[3]:=",ExpressionUUID->"40217f2e-7f19-402e-9508-5b1912b78e4b"],

Cell[BoxData[
 RowBox[{
  RowBox[{"InvRSL", "[", 
   RowBox[{"X_", ",", "d_", ",", 
    RowBox[{"nota1_", ":", "a"}], ",", 
    RowBox[{"nota2_", ":", "b"}]}], "]"}], ":=", 
  RowBox[{"Product", "[", 
   RowBox[{
    RowBox[{"Product", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"nota1", "[", "i", "]"}], "*", 
         RowBox[{"nota2", "[", "j", "]"}], "X"}]}], ")"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "1", ",", "d"}], "}"}]}], "]"}]}]], "Input",
 CellLabel->"In[4]:=",ExpressionUUID->"a8e8b876-dce7-4800-9e0c-9eb0bcd875f3"],

Cell[BoxData[
 RowBox[{"(*", 
  RowBox[{"x", "=", " ", 
   RowBox[{"p", "^", 
    RowBox[{"(", 
     RowBox[{"-", "s"}], ")"}]}]}], "*)"}]], "Input",ExpressionUUID->\
"f2ecf8af-ef5b-434b-8301-074ec4016a4e"],

Cell[BoxData[
 RowBox[{
  RowBox[{"RawH", "[", 
   RowBox[{"x_", ",", "d_"}], "]"}], ":=", 
  RowBox[{"Cancel", "[", 
   RowBox[{
    RowBox[{"InvRSL", "[", 
     RowBox[{"x", ",", "d", ",", "a", ",", "b"}], "]"}], "*", 
    RowBox[{"Sum", "[", 
     RowBox[{
      RowBox[{
       RowBox[{"Schu", "[", 
        RowBox[{"m", ",", "d", ",", "a"}], "]"}], "*", 
       RowBox[{"Schu", "[", 
        RowBox[{"m", ",", "d", ",", "b"}], "]"}], " ", 
       RowBox[{"x", "^", "m"}]}], ",", 
      RowBox[{"{", 
       RowBox[{"m", ",", "0", ",", "Infinity"}], "}"}]}], "]"}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[5]:=",ExpressionUUID->"eecb08d7-9070-4ea5-894f-834fceb61174"],

