Cell[BoxData[
 RowBox[{
  RowBox[{"PolyExpan", "[", 
   RowBox[{"m_", ",", "n_", ",", "d_"}], "]"}], ":=", 
  RowBox[{"Series", "[", 
   RowBox[{
    RowBox[{
     RowBox[{"(", 
      RowBox[{"1", "-", 
       RowBox[{"p", "*", "y"}]}], ")"}], "+", 
     RowBox[{
      RowBox[{"InvRSL", "[", 
       RowBox[{"x", ",", "d", ",", "a", ",", "b"}], "]"}], "*", 
      RowBox[{"(", 
       RowBox[{"1", "/", 
        RowBox[{"RawH", "[", 
         RowBox[{"x", ",", "d"}], "]"}]}], ")"}], "*", 
      RowBox[{"(", 
       RowBox[{
        RowBox[{
         RowBox[{"(", 
          RowBox[{"1", "-", "y"}], ")"}], "^", "2"}], "-", 
        RowBox[{"(", 
         RowBox[{"1", "-", 
          RowBox[{"p", "*", "y"}]}], ")"}]}], ")"}]}]}], ",", 
    RowBox[{"{", 
     RowBox[{"x", ",", "0", ",", "m"}], "}"}], ",", 
    RowBox[{"{", 
     RowBox[{"y", ",", "0", ",", "n"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{{3.990821061076632*^9, 3.9908210690267477`*^9}},
 CellLabel->"In[7]:=",ExpressionUUID->"9ae250f4-a6c0-469d-8686-be89d5f67807"],

