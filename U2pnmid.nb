Cell[BoxData[
 RowBox[{
  RowBox[{"Schu", "[", 
   RowBox[{"n_", ",", "d_", ",", 
    RowBox[{"nota_", ":", "a"}]}], "]"}], ":=", 
  RowBox[{"SchurPolynomial", "[", 
   RowBox[{
    RowBox[{"Table", "[", 
     RowBox[{
      RowBox[{"nota", "[", "i", "]"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"d", "-", "2"}]}], "]"}], ",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], "]"}]}]], "Input",
 CellChangeTimes->{3.99086980609227*^9},
 CellLabel->"In[2]:=",ExpressionUUID->"35f66d06-ea75-4735-934a-0e98a9ebf340"],

Cell[BoxData[
 RowBox[{
  RowBox[{"InvL", "[", 
   RowBox[{"X_", ",", "d_", ",", 
    RowBox[{"nota_", ":", "a"}]}], "]"}], ":=", 
  RowBox[{"Product", "[", 
   RowBox[{
    RowBox[{"(", 
     RowBox[{"1", "-", 
      RowBox[{
       RowBox[{"nota", "[", "i", "]"}], " ", "X"}]}], ")"}], ",", 
    RowBox[{"{", 
     RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{3.990870003020008*^9},
 CellLabel->"In[5]:=",ExpressionUUID->"35b9ca31-bd4c-44f0-8bec-7df5c2164211"],

Cell[BoxData[
 RowBox[{
  RowBox[{"InvRSL", "[", 
   RowBox[{"X_", ",", "d_", ",", 
    RowBox[{"nota1_", ":", "a"}], ",", 
    RowBox[{"nota2_", ":", "b"}]}], "]"}], ":=", 
  RowBox[{"Product", "[", 
   RowBox[{
    RowBox[{"Product", "[", 
     RowBox[{
      RowBox[{"(", 
       RowBox[{"1", "-", 
        RowBox[{
         RowBox[{"nota1", "[", "i", "]"}], "*", 
         RowBox[{"nota2", "[", "j", "]"}], "X"}]}], ")"}], ",", 
      RowBox[{"{", 
       RowBox[{"i", ",", "1", ",", "d"}], "}"}]}], "]"}], ",", 
    RowBox[{"{", 
     RowBox[{"j", ",", "1", ",", "d"}], "}"}]}], "]"}]}]], "Input",
 CellChangeTimes->{3.990870022534872*^9},
 CellLabel->"In[6]:=",ExpressionUUID->"95f64d95-2e2c-4813-bacf-f451d0b83474"],

