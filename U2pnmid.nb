Cell[BoxData[
 RowBox[{
  RowBox[{"L2", "[", 
   RowBox[{"x_", ",", "y_"}], "]"}], ":=", 
  RowBox[{
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Schu", "[", 
       RowBox[{"r", ",", "2", ",", "a"}], "]"}], 
      RowBox[{"x", "^", "r"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"r", ",", "1", ",", "Infinity"}], "}"}]}], "]"}], "+", 
   RowBox[{"Sum", "[", 
    RowBox[{
     RowBox[{
      RowBox[{"Schu", "[", 
       RowBox[{"n", ",", "2", ",", "b"}], "]"}], 
      RowBox[{"y", "^", "n"}], "*", 
      RowBox[{"Sum", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"Schu", "[", 
          RowBox[{
           RowBox[{"n", "+", "r"}], ",", "2", ",", "a"}], "]"}], 
         RowBox[{"x", "^", "r"}]}], ",", 
        RowBox[{"{", 
         RowBox[{"r", ",", "1", ",", "Infinity"}], "}"}]}], "]"}]}], ",", 
     RowBox[{"{", 
      RowBox[{"n", ",", "1", ",", "Infinity"}], "}"}]}], "]"}]}]}]], "Input",
 CellChangeTimes->{{3.9541358621802597`*^9, 3.954135871016412*^9}, {
