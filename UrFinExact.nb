Cell[BoxData[
 RowBox[{
  RowBox[{"coeffsAndMonoms", "[", 
   RowBox[{"p_", ",", "vars_"}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"rules", ",", "exps", ",", "coeffs", ",", "monoms"}], "}"}], ",", 
    RowBox[{
     RowBox[{"rules", "=", 
      RowBox[{"CoefficientRules", "[", 
       RowBox[{"p", ",", "vars"}], "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"exps", "=", 
      RowBox[{"Keys", "[", "rules", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"coeffs", "=", 
      RowBox[{"Values", "[", "rules", "]"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"monoms", "=", 
      RowBox[{
       RowBox[{
        RowBox[{"Times", "@@", 
         RowBox[{"MapThread", "[", 
          RowBox[{"Power", ",", 
           RowBox[{"{", 
            RowBox[{"vars", ",", "#"}], "}"}]}], "]"}]}], "&"}], "/@", 
       "exps"}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"{", 
      RowBox[{"coeffs", ",", "monoms"}], "}"}]}]}], "]"}]}]], "Input",
 CellLabel->"In[9]:=",ExpressionUUID->"37168d04-6c28-4f8b-95ac-64c9089d56ad"],

Cell[BoxData[
 RowBox[{
  RowBox[{"commonMonomialFactor", "[", 
   RowBox[{"expr_", ",", "vars_", ",", 
    RowBox[{"ass_", ":", "True"}]}], "]"}], ":=", 
  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", 
     RowBox[{"terms", ",", "exps", ",", "mins"}], "}"}], ",", 
    RowBox[{
     RowBox[{"terms", "=", 
      RowBox[{"List", "@@", 
       RowBox[{"Expand", "[", "expr", "]"}]}]}], ";", "\[IndentingNewLine]", 
     RowBox[{"exps", "=", 
      RowBox[{"Table", "[", 
       RowBox[{
        RowBox[{"Exponent", "[", 
         RowBox[{"t", ",", "v"}], "]"}], ",", 
        RowBox[{"{", 
         RowBox[{"t", ",", "terms"}], "}"}], ",", 
        RowBox[{"{", 
         RowBox[{"v", ",", "vars"}], "}"}]}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"mins", "=", 
      RowBox[{"Simplify", "[", 
       RowBox[{
        RowBox[{"Min", "/@", 
         RowBox[{"Transpose", "[", "exps", "]"}]}], ",", "ass"}], "]"}]}], 
     ";", "\[IndentingNewLine]", 
     RowBox[{"Times", "@@", 
      RowBox[{"MapThread", "[", 
       RowBox[{
        RowBox[{
         RowBox[{"#1", "^", "#2"}], "&"}], ",", 
        RowBox[{"{", 
         RowBox[{"vars", ",", "mins"}], "}"}]}], "]"}]}]}]}], 
   "]"}]}]], "Input",
 CellLabel->"In[10]:=",ExpressionUUID->"897d0b80-0e6e-42bc-99af-dbc4109ee5b0"],

Cell[BoxData[
 RowBox[{
