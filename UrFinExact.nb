  RowBox[{"Module", "[", 
   RowBox[{
    RowBox[{"{", "fac", "}"}], ",", 
    RowBox[{
     RowBox[{"fac", "=", 
      RowBox[{"commonMonomialFactor", "[", 
       RowBox[{"expr", ",", "vars", ",", "ass"}], "]"}]}], ";", 
     "\[IndentingNewLine]", 
     RowBox[{"fac", " ", 
      RowBox[{"FullSimplify", "[", 
       RowBox[{
        RowBox[{"expr", "/", "fac"}], ",", "ass"}], "]"}]}]}]}], 
   "]"}]}]], "Input",
