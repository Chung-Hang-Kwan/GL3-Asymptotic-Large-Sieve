    RowBox[{"Join", "[", 
     RowBox[{
      RowBox[{"ConstantArray", "[", 
       RowBox[{"0", ",", 
        RowBox[{"d", "-", "2"}]}], "]"}], ",", 
      RowBox[{"{", "n", "}"}]}], "]"}]}], "]"}]}]], "Input",
